{
  "mcpServers": {
    "csv-word-converter": {
      "command": "python",
      "args": [
        "d:\\桌面\\clientab-main\\mcp_integration\\mcp_server.py"
      ],
      "env": {
        "PYTHONPATH": "d:\\桌面\\clientab-main\\src"
      }
    }
  },
  "server_info": {
    "name": "CSV-Word转换工具MCP服务器",
    "version": "1.0.0",
    "description": "提供CSV到Word文档转换功能的MCP服务器，支持多种模板和批量处理",
    "author": "AI Development Team",
    "capabilities": [
      "convert_csv_to_word",
      "batch_convert_csv", 
      "get_available_templates",
      "validate_csv_file",
      "get_conversion_status",
      "create_temp_workspace",
      "cleanup_temp_workspace"
    ],
    "supported_formats": {
      "input": ["csv"],
      "output": ["docx", "pdf"]
    },
    "requirements": {
      "python": ">=3.8",
      "dependencies": [
        "python-docx>=0.8.11",
        "pandas>=1.3.0",
        "pyyaml>=5.4.0",
        "requests>=2.25.0",
        "pillow<11,>=7.1.0",
        "mcp>=0.1.0"
      ]
    }
  },
  "usage_examples": {
    "single_conversion": {
      "tool": "convert_csv_to_word",
      "description": "转换单个CSV文件",
      "example": {
        "csv_file_path": "d:\\data\\sample.csv",
        "template_type": "guoziwei",
        "output_dir": "d:\\output"
      }
    },
    "batch_conversion": {
      "tool": "batch_convert_csv",
      "description": "批量转换多个CSV文件",
      "example": {
        "csv_files": [
          "d:\\data\\file1.csv",
          "d:\\data\\file2.csv"
        ],
        "template_type": "new_energy",
        "output_dir": "d:\\output",
        "max_workers": 4
      }
    },
    "template_list": {
      "tool": "get_available_templates",
      "description": "获取可用模板列表",
      "example": {}
    },
    "file_validation": {
      "tool": "validate_csv_file",
      "description": "验证CSV文件格式",
      "example": {
        "csv_file_path": "d:\\data\\sample.csv"
      }
    }
  },
  "error_handling": {
    "common_errors": {
      "file_not_found": "指定的CSV文件不存在",
      "invalid_template": "指定的模板类型不可用",
      "conversion_failed": "转换过程中发生错误",
      "permission_denied": "没有足够的权限访问文件或目录"
    },
    "troubleshooting": {
      "check_file_path": "确保CSV文件路径正确且文件存在",
      "check_permissions": "确保有读取CSV文件和写入输出目录的权限",
      "check_template": "使用get_available_templates工具查看可用模板",
      "check_format": "使用validate_csv_file工具验证CSV文件格式"
    }
  }
}